  <script>
    // ─── Fade-Up Observer ───
    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-up').forEach(el => fadeObserver.observe(el));

    // ─── Nav Scroll Effect ───
    const nav = document.getElementById('nav');
    const navLogo = document.getElementById('navLogo');
    const navLinks = [document.getElementById('nl1'), document.getElementById('nl2'), document.getElementById('nl3')];
    const navCTA = document.getElementById('navCTA');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        nav.classList.add('bg-off-white/90', 'backdrop-blur-md', 'shadow-sm');
        navLogo.classList.remove('text-off-white');
        navLogo.classList.add('text-warm-dark');
        navLinks.forEach(l => {
          l.classList.remove('text-off-white/70');
          l.classList.add('text-warm-mid');
          l.classList.remove('hover:text-off-white');
          l.classList.add('hover:text-warm-dark');
        });
        if (navCTA) {
          navCTA.classList.remove('bg-terracotta/90');
          navCTA.classList.add('bg-terracotta');
        }
        document.getElementById('mobileMenu').classList.remove('text-off-white');
        document.getElementById('mobileMenu').classList.add('text-warm-dark');
      } else {
        nav.classList.remove('bg-off-white/90', 'backdrop-blur-md', 'shadow-sm');
        navLogo.classList.add('text-off-white');
        navLogo.classList.remove('text-warm-dark');
        navLinks.forEach(l => {
          l.classList.add('text-off-white/70');
          l.classList.remove('text-warm-mid');
          l.classList.add('hover:text-off-white');
          l.classList.remove('hover:text-warm-dark');
        });
        if (navCTA) {
          navCTA.classList.add('bg-terracotta/90');
          navCTA.classList.remove('bg-terracotta');
        }
        document.getElementById('mobileMenu').classList.add('text-off-white');
        document.getElementById('mobileMenu').classList.remove('text-warm-dark');
      }
    });

    // ─── Mobile Menu ───
    document.getElementById('mobileMenu').addEventListener('click', () => {
      document.getElementById('mobileNav').classList.toggle('hidden');
    });
    document.querySelectorAll('#mobileNav a').forEach(a => {
      a.addEventListener('click', () => document.getElementById('mobileNav').classList.add('hidden'));
    });

    // ─── Typewriter on Hover ───
    document.querySelectorAll('.teacher-quote').forEach(quote => {
      const fullText = quote.dataset.quote;
      const textSpan = quote.querySelector('.quote-text');
      const cursorSpan = quote.querySelector('.cursor-placeholder');
      let typewriterInterval = null;
      let currentChar = 0;

      function reset() {
        if (typewriterInterval) clearInterval(typewriterInterval);
        typewriterInterval = null;
        currentChar = 0;
        textSpan.textContent = '';
        cursorSpan.className = 'cursor-placeholder';
        cursorSpan.textContent = '';
      }

      function start() {
        reset();
        cursorSpan.className = 'typewriter-cursor';
        typewriterInterval = setInterval(() => {
          if (currentChar < fullText.length) {
            textSpan.textContent += fullText[currentChar];
            currentChar++;
          } else {
            clearInterval(typewriterInterval);
            typewriterInterval = null;
            setTimeout(() => {
              cursorSpan.className = 'cursor-placeholder';
              cursorSpan.textContent = '';
            }, 1500);
          }
        }, 28);
      }

      const card = quote.closest('.group');
      card.addEventListener('mouseenter', start);
      card.addEventListener('mouseleave', reset);
      card.addEventListener('touchstart', (e) => {
        e.preventDefault();
        typewriterInterval ? reset() : start();
      }, { passive: false });
    });

    // ─── Chime on First Scroll ───
    let soundEnabled = false;
    let chimePlayed = false;

    function playChime() {
      if (chimePlayed || !soundEnabled) return;
      chimePlayed = true;
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const now = ctx.currentTime;
      [528, 792].forEach((freq, i) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, now);
        gain.gain.setValueAtTime(0, now);
        gain.gain.linearRampToValueAtTime(i === 0 ? 0.08 : 0.03, now + 0.08);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + 3);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(now);
        osc.stop(now + 3);
      });
      setTimeout(() => {
        const osc2 = ctx.createOscillator();
        const gain2 = ctx.createGain();
        osc2.type = 'sine';
        osc2.frequency.setValueAtTime(1056, ctx.currentTime);
        gain2.gain.setValueAtTime(0, ctx.currentTime);
        gain2.gain.linearRampToValueAtTime(0.012, ctx.currentTime + 0.1);
        gain2.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 2.5);
        osc2.connect(gain2);
        gain2.connect(ctx.destination);
        osc2.start(ctx.currentTime);
        osc2.stop(ctx.currentTime + 2.5);
      }, 200);
    }

    setTimeout(() => document.getElementById('soundToast').classList.add('show'), 2500);
    document.getElementById('enableSound').addEventListener('click', () => {
      soundEnabled = true;
      document.getElementById('soundToast').classList.remove('show');
    });
    document.getElementById('dismissSound').addEventListener('click', () => {
      document.getElementById('soundToast').classList.remove('show');
    });
    window.addEventListener('scroll', () => { if (window.scrollY > 200) playChime(); }, { passive: true });

    // ─── Quote Form → WhatsApp ───
    document.getElementById('quoteForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const f = e.target;
      const name = f.querySelector('[name="name"]').value.trim();
      const type = f.querySelector('[name="type"]').value;
      const msg = f.querySelector('[name="message"]').value.trim();
      let text = "Hi, I'd like a website + domain quote.";
      if (name) text += `\n\nBusiness name: ${name}`;
      if (type) text += `\nBusiness type: ${type}`;
      if (msg) text += `\nDetails: ${msg}`;
      window.open(`https://wa.me/2348169929738?text=${encodeURIComponent(text)}`, '_blank');
      f.reset();
    });
  </script>
